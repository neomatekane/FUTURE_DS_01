        "import pandas as pd\n",
        "df = pd.read_csv('/content/train.csv')\n",
        "df = df.drop_duplicates() #drop duplicates\n",
        "df['Postal Code'] = df['Postal Code'].fillna(0)#drop missing values\n",
        "df['Postal Code'] = df['Postal Code'].astype(int)#convert to integer\n",
        "df['Order Date'] = pd.to_datetime(df['Order Date'], dayfirst=True)\n",
        "df['Ship Date'] = pd.to_datetime(df['Ship Date'], dayfirst=True)# fix date columns\n",
        "df['Year'] = df['Order Date'].dt.year\n",
        "df['Month'] = df['Order Date'].dt.month\n",
        "df['Month Name'] = df['Order Date'].dt.month_name()\n",
        "df['Day'] = df['Order Date'].dt.day\n",
        "df['Shipping_Days'] = (df['Ship Date'] - df['Order Date']).dt.days\n",
        "text_cols = ['City', 'State', 'Category', 'Sub-Category', 'Product Name']\n",
        "\n",
        "for col in text_cols:\n",
        "    df[col] = df[col].str.strip().str.title()\n",
        "df = df.drop(columns=['Row ID', 'Customer ID', 'Customer Name', 'Product ID'])\n",
        "df = df[df['Sales'] > 0] #remove negative values\n",
        "df.to_csv('/content/cleaned_train.csv', index=False)# save clean data"
