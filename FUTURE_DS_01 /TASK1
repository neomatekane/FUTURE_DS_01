      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from google.colab import files\n",
        "\n",
        "# Load cleaned data\n",
        "df = pd.read_csv('/content/cleaned_train.csv')\n",
        "monthly_sales = df.groupby(['Year', 'Month'])['Sales'].sum().reset_index()#revenue over time\n",
        "top_products = df.groupby('Product Name')['Sales'].sum().sort_values(ascending=False).head(10)#top products\n",
        "category_sales = df.groupby('Category')['Sales'].sum()#catergory sales\n",
        "region_sales = df.groupby('Region')['Sales'].sum()#regional sales\n",
        "shipping = df.groupby('Ship Mode')['Shipping_Days'].mean()#shipping performance\n",
        "\n",
        "plt.figure(figsize=(18, 12))\n",
        "plt.subplot(2, 3, 1)#revenue trend\n",
        "plt.plot(monthly_sales['Sales'])\n",
        "plt.title(\"Revenue Trend\")\n",
        "plt.subplot(2, 3, 2)#top products\n",
        "top_products.plot(kind='bar')\n",
        "plt.title(\"Top Products\")\n",
        "plt.subplot(2, 3, 3)#category sales\n",
        "category_sales.plot(kind='bar')\n",
        "plt.title(\"Category Sales\")\n",
        "plt.subplot(2, 3, 4)#regional sales\n",
        "region_sales.plot(kind='bar')\n",
        "plt.title(\"Region Sales\")\n",
        "plt.subplot(2, 3, 5)#shipping sales\n",
        "shipping.plot(kind='bar')\n",
        "plt.title(\"Shipping Time\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "plt.savefig('Revenue_Trend.png')\n",
        "files.download('Revenue_Trend.png')\n",
        "plt.savefig('Top_Products.png')\n",
        "files.download('Top_Products.png')\n",
        "plt.savefig('Category_Sales.png')\n",
        "files.download('Category_Sales.png')\n",
        "plt.savefig('Region_Sales.png')\n",
        "files.download('Region_Sales.png')"
      ],
